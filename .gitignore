# ══════════════════════════════════════
# Athlete Pro / Fit Elite — .gitignore
# ══════════════════════════════════════

# ===== СЕКРЕТЫ =====
.env
.env.*
!.env.example
# env.js — локальные ключи Supabase (НЕ коммитить!)
/env.js
*.pem
*.key
# Planning notes may contain keys
.planning/


# ===== Claude Code =====
# settings.local.json = личные ключи/MCP → НЕ коммитить
# settings.json = командные правила → КОММИТИТЬ
.claude/settings.local.json

# ===== Node =====
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===== Logs =====
logs/
*.log

# ===== OS =====
.DS_Store
Thumbs.db
Desktop.ini

# ===== IDE =====
# Игнорируем личные настройки, но НЕ extensions.json
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ===== Deploy =====
.vercel/

# ===== Tests =====
coverage/
*.lcov